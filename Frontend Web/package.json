{
  "name": "smart-stock",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "eslint src/**/*.{ts,html}",
    "lint:fix": "eslint src/**/*.{ts,html} --fix",
    "format": "prettier --write src/**/*.{ts,html,css,scss,json}",
    "format:check": "prettier --check src/**/*.{ts,html,css,scss,json}",
    "code:check": "npm run lint && npm run format:check",
    "code:fix": "npm run lint:fix && npm run format"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
