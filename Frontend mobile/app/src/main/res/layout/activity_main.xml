<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SmartStock Mobile"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeaderSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Control de inventario en tiempo real"
            android:textColor="#D6E7F8"
            android:textSize="13sp" />
    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <HorizontalScrollView
        android:id="@+id/navScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/bottomNavLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="10dp">

            <Button
                android:id="@+id/btnNavHome"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="96dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Inicio"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnNavUsers"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="96dp"
                android:text="Usuarios"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnNavProducts"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="96dp"
                android:text="Productos"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnNavTasks"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="96dp"
                android:text="Tareas"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnNavInventory"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="96dp"
                android:text="Inventario"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnNavMovements"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="96dp"
                android:text="Movimientos"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnNavReports"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="96dp"
                android:text="Reportes"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_nav_button"
                android:minWidth="96dp"
                android:text="Perfil"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
