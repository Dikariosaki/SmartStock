<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView android:id="@+id/tvTaskTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textStyle="bold" android:textSize="17sp" android:textColor="@color/text_primary" />
    <TextView android:id="@+id/tvTaskDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" />
    <TextView android:id="@+id/tvTaskAssigned" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" />
    <TextView android:id="@+id/tvTaskDates" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/text_secondary" />
    <TextView android:id="@+id/tvTaskStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layoutTaskActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">
        <Button android:id="@+id/btnEditTask" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:text="Editar" android:textAllCaps="false" />
        <Button android:id="@+id/btnToggleTask" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:textAllCaps="false" />
        <Button android:id="@+id/btnDeleteTask" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:text="Eliminar" android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
